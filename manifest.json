{
  "manifest_version": 3,
  "name": "IMDB Play Button",
  "version": "1.0",
  "description": "Quickly navigate to IMDB play page from any movie",
  "permissions": ["activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.imdb.com/*"],
      "js": ["content.js"]
    }
  ]
}